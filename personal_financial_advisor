def finance_advisor(question, audio):
    if audio is not None:
        speech_text = speech_to_text(audio)

        if question and question.strip():
            question = f"{speech_text}\n\nAdditional text: {question}"
        else:
            question = speech_text

    if not question or question.strip() == "":
        return "", "Please enter text or record audio.", None

    response = agent.invoke({
        "messages": [{"role": "user", "content": question}]
    })

    answer = response["messages"][-1].content[0]["text"]
    audio_path = text_to_speech(answer)

    return question, answer, audio_path


demo = gr.Interface(
    fn=finance_advisor,
    inputs=[gr.Textbox(lines=2, placeholder="Ask a finance question...", label="Question"),gr.Audio(sources=["microphone", "upload"], type="filepath", label="Ask your question")],
    outputs=[
        gr.Textbox(label="Your Question (transcribed)"),
        gr.Textbox(lines=10, label="Answer"),
        gr.Audio(label="Answer (audio)"),
    ],
    title="Personal Finance AI Advisor",
    description="Ask about gold prices, silver prices, GST rates, tax saving options, and more.",
)
demo.launch(debug=True, share=True)
